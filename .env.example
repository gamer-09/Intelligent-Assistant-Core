# Server port (default: 3001)
PORT=3001

# Optional: enables the Gemini tab/route (server/src/core/geminiClient.ts,
# server/src/routes/gemini.ts). Leave blank to run fully offline — every
# other feature works without it.
GEMINI_API_KEY=

# Optional: read-only local file access for the assistant. Set this to the
# ONE folder on this machine you're comfortable letting the assistant look
# at (e.g. C:\Users\you\Documents). Leave blank to keep this disabled.
# The assistant can only list/read files inside this folder — never write,
# delete, or run anything, and never any path outside it.
ASSISTANT_FS_ROOT=C:\Users\samue\Documents
